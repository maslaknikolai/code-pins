{
  "name": "code-pins",
  "displayName": "code-pins",
  "description": "Graphs or whatever",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-pins.addPin",
        "title": "Code Pins: Add pin"
      },
      {
        "command": "code-pins.addReferences",
        "title": "Code Pins: Add All References of Symbol"
      },
      {
        "command": "code-pins.showPanel",
        "title": "Code Pins: Show Panel"
      },
      {
        "command": "code-pins.clearActiveGraph",
        "title": "Code Pins: Clear Active Graph"
      },
      {
        "command": "code-pins.wipeStorage",
        "title": "Code Pins: Wipe Storage (dev)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "code-pins.wipeStorage",
          "when": "codePins.isDev"
        }
      ],
      "editor/context": [
        {
          "command": "code-pins.addReferences",
          "when": "editorTextFocus",
          "group": "codePins"
        }
      ]
    },
    "keybindings": [
      {
        "command": "code-pins.addPin",
        "key": "ctrl+y",
        "mac": "ctrl+y",
        "when": "editorTextFocus || (!editorIsOpen && !terminalFocus)"
      },
      {
        "command": "code-pins.addReferences",
        "key": "ctrl+shift+y",
        "mac": "ctrl+shift+y",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js && pnpm run build:tailwind",
    "build:tailwind": "tailwindcss -i src/webview/tailwind.css -o dist/tailwind.css",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tailwind": "pnpm run build:tailwind --watch=always",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production && pnpm run build:tailwind --minify",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "pnpm run compile-tests && mocha --ui tdd 'out/**/*.unit.test.js'"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/cli": "^4.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@xyflow/react": "^12.11.2",
    "clsx": "^2.1.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "jotai": "^2.20.1",
    "mocha": "^11.7.6",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "radix-ui": "^1.6.2",
    "tiny-invariant": "^1.3.3"
  }
}
