{
  "name": "code-pins",
  "displayName": "code-pins",
  "description": "Graphs or whatever",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-pins.pin",
        "title": "Code Pins: Pin Symbol to Map"
      },
      {
        "command": "code-pins.showMap",
        "title": "Code Pins: Show Map"
      },
      {
        "command": "code-pins.saveMap",
        "title": "Code Pins: Save Map"
      },
      {
        "command": "code-pins.openMap",
        "title": "Code Pins: Open Map"
      },
      {
        "command": "code-pins.newMap",
        "title": "Code Pins: New Map"
      }
    ],
    "keybindings": [
      {
        "command": "code-pins.pin",
        "key": "ctrl+y",
        "mac": "ctrl+y",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@xyflow/react": "^12.11.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "jotai": "^2.20.1",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
